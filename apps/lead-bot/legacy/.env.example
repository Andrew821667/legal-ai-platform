# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# OpenAI API Key
OPENAI_API_KEY=sk-proj-...
# Для DeepSeek (OpenAI-compatible API), например: https://api.deepseek.com/v1
OPENAI_BASE_URL=

# Admin Telegram ID (ваш ID, получить у @userinfobot)
ADMIN_TELEGRAM_ID=123456789

# Leads Chat ID (опционально - ID чата/канала для уведомлений о лидах)
# Если не указан, уведомления отправляются напрямую админу
# Для получения ID: добавьте бота в группу/канал, отправьте сообщение и используйте @userinfobot
LEADS_CHAT_ID=
ALLOW_ADMIN_TEST_LEADS=1
# Список реально готовых модулей через запятую (ключи каталога):
# consultation_30m, process_audit, lead_intake_pilot, contract_review_assist,
# litigation_assist, compliance_monitoring, legal_ops_outsource, custom_integrations
AVAILABLE_SERVICE_MODULES=consultation_30m,process_audit

# Compliance URLs (документы)
PRIVACY_POLICY_URL=https://legalaipro.ru/privacy
TRANSBORDER_CONSENT_URL=https://legalaipro.ru/transborder-consent
USER_AGREEMENT_URL=https://legalaipro.ru/user-agreement
AI_POLICY_URL=https://legalaipro.ru/ai-policy
MARKETING_CONSENT_URL=https://legalaipro.ru/marketing-consent
PRIVACY_CONTACT_EMAIL=privacy@legalaipro.ru

# OpenAI Settings (можно использовать AI_MODEL или OPENAI_MODEL)
AI_MODEL=gpt-4o-mini
MAX_TOKENS=800
MAX_COMPLETION_TOKENS=16000  # Лимит токенов только на ответ (не включает prompt)
TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=25
LLM_MAX_RETRIES=1
STREAMING_PREVIEW=0

# Database
DB_PATH=data/bot.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Bot Behavior
MAX_HISTORY_MESSAGES=15
RESPONSE_DELAY=1

# Email Settings (SMTP) - для отправки lead magnets
# Для Gmail нужно создать App Password: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Андрей Попов - Legal AI
