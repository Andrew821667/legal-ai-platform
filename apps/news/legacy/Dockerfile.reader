FROM python:3.11-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

COPY apps/news/legacy/requirements.reader.txt /tmp/requirements.reader.txt
RUN pip install --no-cache-dir -r /tmp/requirements.reader.txt

COPY apps/news/legacy/app /app/app

CMD ["python", "-u", "-m", "app.reader_bot"]
