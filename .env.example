# ===== REQUIRED: Core =====
DATABASE_URL=postgresql+psycopg://legalai:legalai@postgres:5432/legalai
CORE_API_URL=http://core-api:8000

# ===== REQUIRED: API Keys (scoped) =====
API_KEY_BOT=
API_KEY_NEWS=
API_KEY_WORKER=
API_KEY_ADMIN=

# ===== REQUIRED: Telegram =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_USERNAME=
NEWS_ADMIN_IDS=

# ===== REQUIRED: News Generation =====
NEWS_SOURCE_URLS=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
NEWS_MODEL=deepseek-chat
NEWS_MAX_PER_SOURCE=2
NEWS_SIMILARITY_THRESHOLD=0.48
NEWS_PRIORITY_DOMAINS=
NEWS_HISTORY_SCAN_LIMIT=120
NEWS_WEEKDAY_SLOTS=10:00,16:30
NEWS_SATURDAY_SLOTS=11:00
NEWS_SUNDAY_SLOTS=
NEWS_ALERT_SLOT=19:00
NEWS_ENABLE_ALERT_SLOT=true
NEWS_DEEP_DAYS=tue,thu
NEWS_DIGEST_WEEKDAY=5
NEWS_CTA_SEQUENCE=soft,soft,soft,soft,soft,soft,soft,mid,mid,hard

# ===== REQUIRED: Domain & TLS =====
DOMAIN=legalaipro.ru
ACME_EMAIL=admin@legalaipro.ru

# ===== OPTIONAL: Web Admin (server-side) =====
CORE_API_ADMIN_KEY=

# ===== REQUIRED: Alerts =====
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=

# ===== OPTIONAL: Tuning =====
TZ=Europe/Moscow
CORS_ORIGINS=https://legalaipro.ru,http://localhost:3000
JOB_TIMEOUT_SECONDS=1200
PGUSER=legalai
PGDB=legalai
POSTGRES_USER=legalai
POSTGRES_PASSWORD=legalai
POSTGRES_DB=legalai
HEALTH_WORKER_ACTIVE_MINUTES=10
NEWS_RETRY_FAILED_AFTER_MINUTES=15
