TELEGRAM_CHANNELS=@allthingslegal,@legal_tech,@Law_GPT,@ai_newz,@anthropicai,@googleai,@openai_ru,@ai_machinelearning_big_data
TELEGRAM_FETCH_LIMIT=50
TELEGRAM_FETCH_ENABLED=true
LEAD_BOT_USERNAME=LegalAI_Popov_Andrew
GOOGLE_NEWS_QUERY_RU=("искусственный интеллект" OR "юридический ИИ" OR legaltech OR "автоматизация юротдела" OR "автоматизация юридической функции")
GOOGLE_NEWS_QUERY_EN=("legal AI" OR legaltech OR "AI for lawyers" OR "contract automation" OR "legal operations automation")
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
NEWS_MODEL=deepseek-chat
NEWS_MAX_PER_SOURCE=3
NEWS_SIMILARITY_THRESHOLD=0.48
NEWS_PRIORITY_DOMAINS=news.google.com,pravo.ru,garant.ru,habr.com,vc.ru,tass.ru,rbc.ru,interfax.ru
NEWS_HISTORY_SCAN_LIMIT=120
NEWS_WEEKDAY_SLOTS=10:00,16:30
NEWS_SATURDAY_SLOTS=11:00
NEWS_SUNDAY_SLOTS=
NEWS_ALERT_SLOT=19:00
NEWS_ENABLE_ALERT_SLOT=true
NEWS_DEEP_DAYS=tue,thu
NEWS_DIGEST_WEEKDAY=5
NEWS_CTA_SEQUENCE=soft,soft,soft,soft,soft,soft,soft,mid,mid,hard
NEWS_GENERATE_LIMIT=5
NEWS_GENERATE_INTERVAL_SECONDS=1800
NEWS_PUBLISH_INTERVAL_SECONDS=300
